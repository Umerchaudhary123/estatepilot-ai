{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "NIXPACKS", "buildCommand": "cd ../.. && npm run build -w @estatepilot/shared && npm run build -w @estatepilot/api" },
  "deploy": { "startCommand": "node dist/main.js", "healthcheckPath": "/api/health", "healthcheckTimeout": 120, "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 3 }
}
